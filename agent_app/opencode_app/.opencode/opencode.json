{
  "$schema": "https://opencode.ai/config.json",
  "model": "DeepSeek_custom_provider/deepseek-chat",
  "provider": {
    "DeepSeek_custom_provider": {
      "models": {
        "deepseek-chat": {
          "name": "deepseek-chat",
          "limit": {
            "context": 128000,
            "output": 4096
          }
        }
      },
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek custom provider",
      "options": {
        "baseURL": "https://api.deepseek.com/v1",
        "apiKey": "{env:DEEPSEEK_API_KEY}"
      }
    }
  },
  "default_agent": "ThreatIntelPrimary",
  "workspace": {
    "root": "agent_app/opencode_app/.opencode",
    "control_plane_root": ".opencode"
  },
  "agent_roles": {
    "primary": "ThreatIntelPrimary",
    "analyst": "ThreatIntelAnalyst",
    "secops": "ThreatIntelSecOps"
  },
  "agent_aliases": {
    "ThreatIntelligenceCommander": "ThreatIntelPrimary",
    "STIX_EvidenceSpecialist": "ThreatIntelAnalyst",
    "TARA_analyst": "ThreatIntelSecOps"
  },
  "instructions": [
    "AGENTS.md"
  ],
  "permission": {
    "mcp_*": "ask",
    "skill": {
      "*": "allow"
    }
  }
}
