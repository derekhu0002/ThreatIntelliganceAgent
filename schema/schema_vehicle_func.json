{
"$schema": "http://json-schema.org/draft-07/schema#",
"title": "STIX 2.1 Vehicle Function Schema",
"description": "适配车辆功能数据，符合 STIX2.1+MongoDB 存储标准",
"type": "object",
"properties": {
    "type": {
    "type": "string",
    "const": "bundle"
    },
    "id": {
    "type": "string",
    "pattern": "^bundle--[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "objects": {
    "type": "array",
    "description": "STIX2.1 扩展对象集合：车辆功能",
    "items": {
        "type": "object",
        "description": "自定义 STIX2.1 扩展对象：车辆功能",
        "properties": {
        "type": {
            "type": "string",
            "const": "x-vehicle-function"
        },
        "id": {
            "type": "string",
            "pattern": "^x-vehicle-function--[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
        },
        "function_id": {
            "type": "string",
            "description": "功能 ID"
        },
        "function_name": {
            "type": "string",
            "description": "功能名称"
        },
        "function_description": {
            "type": "string",
            "description": "功能描述"
        },
        "related_ecus": {
            "type": "array",
            "items": {
            "type": "string"
            },
            "description": "相关 ECU 列表"
        },
        "x_domain_tag": {
            "type": "string",
            "description": "域/车型/版本数据标签，用于多车型或平台化区分。"
        }
        },
        "required": [
        "type",
        "id",
        "function_id",
        "function_name",
        "function_description",
        "related_ecus",
        "x_domain_tag"
        ],
        "additionalProperties": false
    }
    }
},
"required": [
    "type",
    "id",
    "objects"
],
"additionalProperties": false
}